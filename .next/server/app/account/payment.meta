{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/account/layout,_N_T_/account/payment/layout,_N_T_/account/payment/page,_N_T_/account/payment"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/account/payment/__PAGE__",
    "/account/payment",
    "/account",
    "/_index",
    "/_head"
  ]
}